# =============================================================
# Cabinet Dentaire Ayari — Backend Environment Configuration
# =============================================================
# Copy this file to dental-clinic/.env.local and fill values
# =============================================================

# ── App ──────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Database (MySQL) ──────────────────────────────────────────
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
# Local:        mysql://root:password@localhost:3306/ayari_dentiste
# PlanetScale:  mysql://USER:PASSWORD@HOST/DATABASE?sslaccept=strict
# Railway:      mysql://USER:PASSWORD@containers-us-west-XX.railway.app:PORT/railway
# Aiven:        mysql://USER:PASSWORD@HOST:PORT/DATABASE?ssl-mode=REQUIRED
DATABASE_URL="mysql://root:YOUR_PASSWORD@localhost:3306/ayari_dentiste"

# ── JWT Authentication ────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET="your-super-secret-jwt-key-minimum-32-characters-change-this"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-minimum-32-characters-change-this"

# ── Email (SMTP / Gmail / Resend) ────────────────────────────
# Option 1: Gmail SMTP (enable "App Passwords" in Google account)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-clinic-email@gmail.com
SMTP_PASS=your-google-app-password

# Option 2: Custom SMTP (OVH, Ionos, etc.)
# SMTP_HOST=ssl0.ovh.net
# SMTP_PORT=587
# SMTP_USER=contact@ayari-dentiste.tn
# SMTP_PASS=your-email-password

# Clinic contact email (receives appointment notifications)
CLINIC_EMAIL=contact@ayari-dentiste.tn

# ── Cloudinary (optional — for gallery image uploads) ─────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
